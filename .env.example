# Docker Environment File
# Copy this to .env and update values before running docker-compose

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/hostelease
MONGO_PASSWORD=your_mongodb_password

# JWT
JWT_SECRET=your_jwt_secret_key_here
GATE_QR_HMAC_SECRET=your_secret

# Server
PORT=5001
NODE_ENV=production

# Application
APP_NAME=HostelEase
LOG_LEVEL=info
